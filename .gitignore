# Ignore everything by default
*

# Node-RED palette package
!node-red-contrib-abb-gofa/
!node-red-contrib-abb-gofa/**
# ...but not generated/internal files inside it
node-red-contrib-abb-gofa/.claude/
node-red-contrib-abb-gofa/node_modules/
node-red-contrib-abb-gofa/package-lock.json

# Node-RED flows
!flows/
!flows/gofa_demo_flow.json
!flows/dashboard_flow.json
!flows/gofa_payload_test_flow.json
!flows/teach_workflow_flow.json
!flows/setup_flow.json
!flows/pickplace_sorting_flow.json

# RAPID program
!rapid/
!rapid/MainModule.mod
!rapid/MainModuleEGM.mod
!rapid/BackgroundLed.mod

# This file, README, license, CI, and Claude Code project config
!.gitignore
!README.md
!LICENSE
!CLAUDE.md
!MANUAL_CONTROL.md
!.github/
!.github/**
!/.claude/
!/.claude/**
# ...except local machine settings (permission allowlist, local paths) — not for a public repo
/.claude/settings.local.json

# Runtime files (generated locally, not for version control)
# points.json  — saved robot positions, created by gofa-save-point at runtime
